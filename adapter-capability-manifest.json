      "effect_classes": ["inspect"],
      "external_effect_supported": false,
      "projection_registry": "collective_phase_control_fabric.adapters.PROJECTION_MAPPINGS"
    },
    {
      "adapter": "pic",
      "supported_source_version": "1.1.0",
      "operations": ["agent_explain", "agent_check", "phase_plan", "canonical_readiness"],
      "effect_classes": ["inspect", "validate", "plan"],
      "external_effect_supported": false,
      "projection_registry": "collective_phase_control_fabric.adapters.PROJECTION_MAPPINGS"
    }
  ]
}

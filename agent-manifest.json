{
  "manifest_version": "0.6.0",
  "name": "cpcf",
  "version": "0.6.0",
  "cli": "cpcf",
  "development_environment": "uv 0.11.28 with Python 3.14.6",
  "distribution": "collective-phase-control-fabric",
  "default_mode": "offline_orientation_then_remote_evidence_control",
  "offline_core_supported": true,
  "control_plane_network_required": true,
  "control_plane_executes_adapters": false,
  "external_runner_protocol": "models_and_conformance_only_transport_release_blocked",
  "source_of_record_migration": false,
  "legacy_workspace_execution": false,
  "first_safe_commands": [
    ["cpcf", "agent", "explain", "--json"],
    ["cpcf", "self-check", "--json"],
    ["cpcf", "schema", "list", "--json"]
  ],
  "schemas": [
    "schemas/v0.1.0",
    "schemas/v0.2.0",
    "schemas/v0.3.0",
    "schemas/v0.4.0",
    "schemas/v0.5.0",
    "schemas/v0.6.0"
  ],
  "native_result": "operational_organization_profile",
  "non_claims": [
    "collective superintelligence",
    "consciousness",
    "physical phase transition",
    "truth",
    "causal proof",
    "statistical certification",
    "thermodynamic feasibility",
    "runner containment",
    "operational assurance without release-gate evidence"
  ]
}

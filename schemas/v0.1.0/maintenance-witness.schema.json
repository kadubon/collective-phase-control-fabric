    "renewal_obligations": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "expiry_refresh_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "resource_supply_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "verifier_capacity_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "rollback_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "maintenance_cost_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "failure_response_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "source_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  }

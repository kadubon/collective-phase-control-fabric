{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/cpcf/schemas/v0.1.0/handoff-candidate.schema.json",
  "title": "HandoffCandidate",
  "type": "object",
  "additionalProperties": true,
  "required": ["handoff_id", "source_system", "kind", "downstream_accepted", "source_refs"],
  "properties": {
    "handoff_id": {"type": "string", "minLength": 1},
    "source_system": {"type": "string", "minLength": 1},
    "kind": {
      "enum": [
        "capability_admission_candidate", "proof_carrying_skill_candidate",
        "residual_evidence_candidate", "governed_memory_candidate"
      ]
    },
    "downstream_accepted": {"const": "unknown"},
    "source_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  }
}

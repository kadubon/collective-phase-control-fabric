{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://example.org/cpcf/schemas/v0.2.0/source-artifact-envelope.schema.json","title":"SourceArtifactEnvelope","type":"object","additionalProperties":false,

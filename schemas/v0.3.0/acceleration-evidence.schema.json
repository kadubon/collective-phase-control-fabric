{
  "$id": "https://example.org/cpcf/schemas/v0.3.0/acceleration-evidence.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "evidence_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "propertyNames": {
        "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$"
      },
      "type": "object"
    },
    "protocol_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "reasons": {
      "items": {
        "maxLength": 1024,
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    },
    "result_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "schema_version": {
      "const": "0.3.0"
    },
    "signature": {
      "additionalProperties": false,
      "properties": {
        "key_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
          "type": "string"
        },
        "payload_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "signature_base64": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "signed_at": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "key_id",
        "signature_base64",
        "signed_at",
        "payload_digest"
      ],
      "type": "object"
    },
    "status": {
      "enum": [
        "unmeasured",
        "externally_observed_inconclusive",
        "external_acceleration_bundle_compatible",
        "external_quality_or_safety_contradiction"
      ]
    }
  },
  "required": [
    "schema_version",
    "evidence_id",
    "protocol_digest",
    "result_digest",
    "status",
    "reasons"
  ],
  "title": "CPCF Operational Acceleration Evidence v0.3",
  "type": "object",
  "unevaluatedProperties": false
}

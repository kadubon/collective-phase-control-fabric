{
  "$id": "https://example.org/cpcf/schemas/v0.3.0/workspace-generation.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "analysis_epoch": {
      "format": "date-time",
      "type": "string"
    },
    "contract_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "envelopes": {
      "items": {
        "pattern": "^sha256:[0-9a-f]{64}$",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "extensions": {
      "additionalProperties": true,
      "propertyNames": {
        "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$"
      },
      "type": "object"
    },
    "generation_id": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "history": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "previous_generation": {
      "oneOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "projections": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "object_digest": {
            "pattern": "^sha256:[0-9a-f]{64}$",
            "type": "string"
          },
          "receipt_digest": {
            "pattern": "^sha256:[0-9a-f]{64}$",
            "type": "string"
          },
          "schema_ref": {
            "maxLength": 1024,
            "minLength": 1,
            "type": "string"
          },
          "source_pointer": {
            "pattern": "^(?:/(?:[^~/]|~0|~1)*)*$",
            "type": "string"
          }
        },
        "required": [
          "object_digest",
          "schema_ref",
          "receipt_digest",
          "source_pointer"
        ],
        "type": "object"
      },
      "type": "array",
      "uniqueItems": true
    },
    "quarantine": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "raw_artifacts": {
      "items": {
        "pattern": "^sha256:[0-9a-f]{64}$",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "receipts": {
      "items": {
        "pattern": "^sha256:[0-9a-f]{64}$",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "schema_version": {
      "const": "0.3.0"
    },
    "signature": {
      "additionalProperties": false,
      "properties": {
        "key_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
          "type": "string"
        },
        "payload_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "signature_base64": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "signed_at": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "key_id",
        "signature_base64",
        "signed_at",
        "payload_digest"
      ],
      "type": "object"
    },
    "trust_policy_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "generation_id",
    "previous_generation",
    "contract_digest",
    "trust_policy_digest",
    "analysis_epoch",
    "raw_artifacts",
    "envelopes",
    "receipts",
    "projections",
    "history",
    "quarantine"
  ],
  "title": "CPCF Immutable Workspace Generation v0.3",
  "type": "object",
  "unevaluatedProperties": false
}

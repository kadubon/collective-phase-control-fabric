{
  "$id": "https://example.org/cpcf/schemas/v0.3.0/trust-policy.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "extensions": {
      "additionalProperties": true,
      "propertyNames": {
        "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$"
      },
      "type": "object"
    },
    "policy_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
      "type": "string"
    },
    "principals": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "key_id": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
            "type": "string"
          },
          "not_after": {
            "format": "date-time",
            "type": "string"
          },
          "not_before": {
            "format": "date-time",
            "type": "string"
          },
          "public_key_base64": {
            "maxLength": 1024,
            "minLength": 1,
            "type": "string"
          },
          "revoked": {
            "type": "boolean"
          },
          "roles": {
            "items": {
              "maxLength": 1024,
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array",
            "uniqueItems": true
          },
          "schema_names": {
            "items": {
              "maxLength": 1024,
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array",
            "uniqueItems": true
          },
          "scope": {
            "additionalProperties": {
              "type": [
                "string",
                "integer",
                "boolean",
                "null"
              ]
            },
            "type": "object"
          },
          "source_systems": {
            "items": {
              "maxLength": 1024,
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array",
            "uniqueItems": true
          }
        },
        "required": [
          "key_id",
          "public_key_base64",
          "source_systems",
          "schema_names",
          "roles",
          "scope",
          "not_before",
          "not_after",
          "revoked"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "schema_version": {
      "const": "0.3.0"
    },
    "signature": {
      "additionalProperties": false,
      "properties": {
        "key_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
          "type": "string"
        },
        "payload_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "signature_base64": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "signed_at": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "key_id",
        "signature_base64",
        "signed_at",
        "payload_digest"
      ],
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "policy_id",
    "principals"
  ],
  "title": "CPCF Pinned-Key Trust Policy v0.3",
  "type": "object",
  "unevaluatedProperties": false
}

{
  "$id": "https://example.org/cpcf/schemas/v0.3.0/organization-witness.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "extensions": {
      "additionalProperties": true,
      "propertyNames": {
        "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$"
      },
      "type": "object"
    },
    "flux": {
      "additionalProperties": {
        "pattern": "^-?(?:0|[1-9][0-9]*)(?:/[1-9][0-9]*)?$",
        "type": "string"
      },
      "type": "object"
    },
    "network_ref": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
      "type": "string"
    },
    "schema_version": {
      "const": "0.3.0"
    },
    "signature": {
      "additionalProperties": false,
      "properties": {
        "key_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
          "type": "string"
        },
        "payload_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "signature_base64": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "signed_at": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "key_id",
        "signature_base64",
        "signed_at",
        "payload_digest"
      ],
      "type": "object"
    },
    "source_refs": {
      "items": {
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "state_refs": {
      "items": {
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "target_refs": {
      "items": {
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "transformation_refs": {
      "items": {
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "witness_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "witness_id",
    "network_ref",
    "target_refs",
    "state_refs",
    "transformation_refs",
    "flux",
    "source_refs"
  ],
  "title": "CPCF Closed Self-Maintaining Organization Witness v0.3",
  "type": "object",
  "unevaluatedProperties": false
}

{
  "$id": "https://example.org/cpcf/schemas/v0.3.0/coordination-event-ledger.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "events": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "artifact_digest": {
            "pattern": "^sha256:[0-9a-f]{64}$",
            "type": "string"
          },
          "event_id": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
            "type": "string"
          },
          "event_type": {
            "enum": [
              "commit",
              "consume",
              "reveal",
              "verify",
              "terminate"
            ]
          },
          "independence_domain": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
            "type": "string"
          },
          "occurred_at": {
            "format": "date-time",
            "type": "string"
          },
          "principal_key_id": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
            "type": "string"
          }
        },
        "required": [
          "event_id",
          "event_type",
          "principal_key_id",
          "independence_domain",
          "artifact_digest",
          "occurred_at"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "extensions": {
      "additionalProperties": true,
      "propertyNames": {
        "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$"
      },
      "type": "object"
    },
    "ledger_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
      "type": "string"
    },
    "schema_version": {
      "const": "0.3.0"
    },
    "signature": {
      "additionalProperties": false,
      "properties": {
        "key_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
          "type": "string"
        },
        "payload_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "signature_base64": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "signed_at": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "key_id",
        "signature_base64",
        "signed_at",
        "payload_digest"
      ],
      "type": "object"
    },
    "source_refs": {
      "items": {
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schema_version",
    "ledger_id",
    "events",
    "source_refs"
  ],
  "title": "CPCF Coordination Exposure Ledger v0.3",
  "type": "object",
  "unevaluatedProperties": false
}

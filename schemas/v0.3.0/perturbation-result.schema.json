{
  "$id": "https://example.org/cpcf/schemas/v0.3.0/perturbation-result.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "accepted": {
      "type": "boolean"
    },
    "case_results": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "extensions": {
      "additionalProperties": true,
      "propertyNames": {
        "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$"
      },
      "type": "object"
    },
    "result_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
      "type": "string"
    },
    "schema_version": {
      "const": "0.3.0"
    },
    "signature": {
      "additionalProperties": false,
      "properties": {
        "key_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
          "type": "string"
        },
        "payload_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "signature_base64": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "signed_at": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "key_id",
        "signature_base64",
        "signed_at",
        "payload_digest"
      ],
      "type": "object"
    },
    "suite_ref": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "result_id",
    "suite_ref",
    "case_results",
    "accepted"
  ],
  "title": "CPCF Perturbation Replay Result v0.3",
  "type": "object",
  "unevaluatedProperties": false
}

{
  "$id": "https://example.org/cpcf/schemas/v0.3.0/trial-result-certificate.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "analysis_executable_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "assumptions": {
      "items": {
        "maxLength": 1024,
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "completed_at": {
      "format": "date-time",
      "type": "string"
    },
    "dataset_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "effect_intervals": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "direction": {
            "enum": [
              "minimize",
              "maximize"
            ]
          },
          "lower": {
            "pattern": "^-?(?:0|[1-9][0-9]*)(?:/[1-9][0-9]*)?$",
            "type": "string"
          },
          "metric": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
            "type": "string"
          },
          "unit": {
            "maxLength": 1024,
            "minLength": 1,
            "type": "string"
          },
          "upper": {
            "pattern": "^-?(?:0|[1-9][0-9]*)(?:/[1-9][0-9]*)?$",
            "type": "string"
          }
        },
        "required": [
          "metric",
          "direction",
          "lower",
          "upper",
          "unit"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "evaluator_key_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "propertyNames": {
        "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$"
      },
      "type": "object"
    },
    "protocol_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "quality_intervals": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "direction": {
            "enum": [
              "minimize",
              "maximize"
            ]
          },
          "lower": {
            "pattern": "^-?(?:0|[1-9][0-9]*)(?:/[1-9][0-9]*)?$",
            "type": "string"
          },
          "metric": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
            "type": "string"
          },
          "unit": {
            "maxLength": 1024,
            "minLength": 1,
            "type": "string"
          },
          "upper": {
            "pattern": "^-?(?:0|[1-9][0-9]*)(?:/[1-9][0-9]*)?$",
            "type": "string"
          }
        },
        "required": [
          "metric",
          "direction",
          "lower",
          "upper",
          "unit"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "result_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
      "type": "string"
    },
    "schema_version": {
      "const": "0.3.0"
    },
    "signature": {
      "additionalProperties": false,
      "properties": {
        "key_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
          "type": "string"
        },
        "payload_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "signature_base64": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "signed_at": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "key_id",
        "signature_base64",
        "signed_at",
        "payload_digest"
      ],
      "type": "object"
    },
    "source_refs": {
      "items": {
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "time_uniform": {
      "type": "boolean"
    }
  },
  "required": [
    "schema_version",
    "result_id",
    "protocol_digest",
    "dataset_digest",
    "analysis_executable_digest",
    "completed_at",
    "effect_intervals",
    "quality_intervals",
    "time_uniform",
    "assumptions",
    "source_refs",
    "evaluator_key_id",
    "signature"
  ],
  "title": "CPCF External Trial Result Certificate v0.3",
  "type": "object",
  "unevaluatedProperties": false
}

{
  "$id": "https://example.org/cpcf/schemas/v0.3.0/adapter-output.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "action_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "propertyNames": {
        "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$"
      },
      "type": "object"
    },
    "message": {
      "maxLength": 1024,
      "minLength": 1,
      "type": "string"
    },
    "observation": {
      "additionalProperties": false,
      "properties": {
        "observation_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
          "type": "string"
        },
        "schema_version": {
          "const": "0.3.0"
        },
        "source_refs": {
          "items": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "value": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "observation_id",
        "value",
        "source_refs"
      ],
      "type": "object"
    },
    "outcome": {
      "enum": [
        "success",
        "partial",
        "failure",
        "timeout"
      ]
    },
    "schema_version": {
      "const": "0.3.0"
    },
    "signature": {
      "additionalProperties": false,
      "properties": {
        "key_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
          "type": "string"
        },
        "payload_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "signature_base64": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "signed_at": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "key_id",
        "signature_base64",
        "signed_at",
        "payload_digest"
      ],
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "action_id",
    "outcome"
  ],
  "title": "CPCF Bounded Adapter Output v0.3",
  "type": "object",
  "unevaluatedProperties": false
}

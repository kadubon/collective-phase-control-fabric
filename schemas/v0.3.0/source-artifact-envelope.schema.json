{
  "$id": "https://example.org/cpcf/schemas/v0.3.0/source-artifact-envelope.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "envelope_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "propertyNames": {
        "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$"
      },
      "type": "object"
    },
    "imported_at": {
      "format": "date-time",
      "type": "string"
    },
    "lifecycle": {
      "additionalProperties": false,
      "properties": {
        "expires_at": {
          "format": "date-time",
          "type": "string"
        }
      },
      "type": "object"
    },
    "lineage": {
      "items": {
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "raw_artifact_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "raw_size": {
      "minimum": 0,
      "type": "integer"
    },
    "schema_ref": {
      "maxLength": 1024,
      "minLength": 1,
      "type": "string"
    },
    "schema_version": {
      "const": "0.3.0"
    },
    "scope": {
      "additionalProperties": {
        "type": [
          "string",
          "integer",
          "boolean",
          "null"
        ]
      },
      "type": "object"
    },
    "signature": {
      "additionalProperties": false,
      "properties": {
        "key_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
          "type": "string"
        },
        "payload_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "signature_base64": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "signed_at": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "key_id",
        "signature_base64",
        "signed_at",
        "payload_digest"
      ],
      "type": "object"
    },
    "signature_requirement": {
      "enum": [
        "required",
        "process_bound"
      ]
    },
    "source_pointers": {
      "items": {
        "pattern": "^(?:/(?:[^~/]|~0|~1)*)*$",
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "source_system": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "envelope_id",
    "source_system",
    "schema_ref",
    "raw_artifact_digest",
    "raw_size",
    "scope",
    "lifecycle",
    "lineage",
    "source_pointers",
    "imported_at",
    "signature_requirement"
  ],
  "title": "CPCF Source Artifact Envelope v0.3",
  "type": "object",
  "unevaluatedProperties": false
}

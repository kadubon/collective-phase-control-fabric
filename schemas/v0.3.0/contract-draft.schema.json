{
  "$id": "https://example.org/cpcf/schemas/v0.3.0/contract-draft.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "candidate_contract": {
      "type": "object"
    },
    "draft_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "propertyNames": {
        "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$"
      },
      "type": "object"
    },
    "missing_decisions": {
      "items": {
        "maxLength": 1024,
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "profile": {
      "enum": [
        "structural",
        "measured"
      ]
    },
    "schema_version": {
      "const": "0.3.0"
    },
    "signature": {
      "additionalProperties": false,
      "properties": {
        "key_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$",
          "type": "string"
        },
        "payload_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "signature_base64": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "signed_at": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "key_id",
        "signature_base64",
        "signed_at",
        "payload_digest"
      ],
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "draft_id",
    "profile",
    "missing_decisions"
  ],
  "title": "CPCF Contract Draft v0.3",
  "type": "object",
  "unevaluatedProperties": false
}

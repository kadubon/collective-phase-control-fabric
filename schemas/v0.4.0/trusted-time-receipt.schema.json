{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://example.org/cpcf/schemas/v0.4.0/trusted-time-receipt.schema.json","title":"CPCF Trusted Time Receipt Payload v0.4","type":"object","properties":{"schema_version":{"const":"0.4.0"},"receipt_id":{"type":"string","minLength":1,"maxLength":256},"receipt_type":{"const":"trusted_time"},"event_time":{"type":"string","format":"date-time"},"subject_digest":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},"serial":{"type":"integer","minimum":0},"extensions":{"type":"object","propertyNames":{"pattern":"^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$"}}},"required":["schema_version","receipt_id","receipt_type","event_time","subject_digest","serial"],"unevaluatedProperties":false}

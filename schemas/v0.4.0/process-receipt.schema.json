{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://example.org/cpcf/schemas/v0.4.0/process-receipt.schema.json","title":"CPCF Process Receipt v0.4","type":"object","properties":{"schema_version":{"const":"0.4.0"},"receipt_id":{"type":"string","minLength":1,"maxLength":256},"executable_digest":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},"invocation_digest":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},"return_code":{"oneOf":[{"type":"integer"},{"type":"null"}]},"timed_out":{"type":"boolean"},"stdout_digest":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},"stderr_digest":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},"stdout_captured_bytes":{"type":"integer","minimum":0},"stdout_discarded_bytes":{"type":"integer","minimum":0},"stderr_captured_bytes":{"type":"integer","minimum":0},"stderr_discarded_bytes":{"type":"integer","minimum":0},"environment_keys":{"type":"array","maxItems":64,"uniqueItems":true,"items":{"type":"string"}},"workspace_before_digest":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},"workspace_after_digest":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},"sandbox_status":{"enum":["not_provided","externally_attested"]}},"required":["schema_version","receipt_id","executable_digest","invocation_digest","return_code","timed_out","stdout_digest","stderr_digest","stdout_captured_bytes","stdout_discarded_bytes","stderr_captured_bytes","stderr_discarded_bytes","environment_keys","workspace_before_digest","workspace_after_digest","sandbox_status"],"unevaluatedProperties":false}

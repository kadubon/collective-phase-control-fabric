{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/cpcf/schemas/v0.4.0/principal-attestation.schema.json",
  "title": "CPCF Principal Attestation Payload v0.4",
  "$defs": {
    "idArray": {
      "type": "array",
      "maxItems": 10000,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 256}
    },
    "rational": {"type": "string", "pattern": "^-?(?:0|[1-9][0-9]*)(?:/[1-9][0-9]*)?$"},
    "interval": {
      "type": "object",
      "properties": {
        "lower": {"$ref": "#/$defs/rational"},
        "upper": {"$ref": "#/$defs/rational"},
        "unit": {"type": "string", "minLength": 1, "maxLength": 128}
      },
      "required": ["lower", "upper", "unit"],
      "unevaluatedProperties": false
    },
    "branch": {
      "type": "object",
      "properties": {
        "must_add": {"$ref": "#/$defs/idArray"},
        "may_add": {"$ref": "#/$defs/idArray"},
        "must_remove": {"$ref": "#/$defs/idArray"},
        "may_remove": {"$ref": "#/$defs/idArray"},
        "debt": {"$ref": "#/$defs/idArray"},
        "rollback_obligations": {"$ref": "#/$defs/idArray"},
        "independence_domains_removed": {"$ref": "#/$defs/idArray"},
        "resource_intervals": {"type": "object", "maxProperties": 10000, "additionalProperties": {"$ref": "#/$defs/interval"}},
        "time_interval": {"$ref": "#/$defs/interval"},
        "cost_interval": {"$ref": "#/$defs/interval"},
        "quality_interval": {"$ref": "#/$defs/interval"},
        "verification_load_upper": {"$ref": "#/$defs/rational"},
        "projection_possibilities": {"type": "array", "maxItems": 1024, "items": {"type": "object", "properties": {"source_pointer": {"type": "string", "maxLength": 4096}, "target_schema": {"type": "string", "maxLength": 1024}}, "required": ["source_pointer", "target_schema"], "unevaluatedProperties": false}}
      },
      "required": ["must_add", "may_add", "must_remove", "may_remove", "debt", "rollback_obligations", "independence_domains_removed", "resource_intervals", "time_interval", "cost_interval", "quality_interval", "verification_load_upper", "projection_possibilities"],
      "unevaluatedProperties": false
    },
    "attributes": {
      "type": "object",
      "properties": {
        "available": {"type": "boolean"},
        "coordinate": {"type": "string", "minLength": 1, "maxLength": 256},
        "quantity": {"$ref": "#/$defs/rational"},
        "unit": {"type": "string", "minLength": 1, "maxLength": 128},
        "inputs": {"$ref": "#/$defs/idArray"},
        "outputs": {"$ref": "#/$defs/idArray"},
        "authority_refs": {"$ref": "#/$defs/idArray"},
        "evidence_refs": {"$ref": "#/$defs/idArray"},
        "inhibitors": {"$ref": "#/$defs/idArray"},
        "catalyst_clauses": {"type": "array", "maxItems": 1024, "items": {"$ref": "#/$defs/idArray"}},
        "explicitly_uncatalyzed": {"type": "boolean"},
        "coordinate_flows": {"type": "object", "maxProperties": 10000, "additionalProperties": {"$ref": "#/$defs/rational"}},
        "validated_boundary_supply_credit": {"$ref": "#/$defs/rational"},
        "arrival_upper": {"$ref": "#/$defs/rational"},
        "service_lower": {"$ref": "#/$defs/rational"},
        "arrival_unit": {"type": "string", "minLength": 1, "maxLength": 128},
        "service_unit": {"type": "string", "minLength": 1, "maxLength": 128},
        "observation_window": {"type": "object", "properties": {"start": {"type": "string", "format": "date-time"}, "end": {"type": "string", "format": "date-time"}}, "required": ["start", "end"], "unevaluatedProperties": false},
        "routing_amplification": {"$ref": "#/$defs/rational"},
        "independence_domain": {"type": "string", "minLength": 1, "maxLength": 256},
        "source_record_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "arrival_curve": {"type": "array", "maxItems": 100000, "items": {"$ref": "#/$defs/rational"}},
        "service_curve": {"type": "array", "maxItems": 100000, "items": {"$ref": "#/$defs/rational"}},
        "backlog_upper": {"$ref": "#/$defs/rational"},
        "observed_closed_boundary": {"type": "boolean"},
        "commitment_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "observer_attestation_ref": {"type": "string", "minLength": 1, "maxLength": 256},
        "infrastructure_domains": {"$ref": "#/$defs/idArray"},
        "before_commitment": {"type": "boolean"},
        "artifact_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "evidence_type": {"enum": ["source_evidence", "analysis_snapshot", "formation_sequence_witness", "organization_witness", "rate_feasibility_witness", "siphon_coverage_witness", "open_system_resource_profile", "perturbation_suite", "action", "proposal_commitment", "proposal_reveal", "coordination_event"]},
        "analysis_base_generation_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "analysis_snapshot_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "flux": {"type": "object", "minProperties": 1, "maxProperties": 10000, "additionalProperties": {"$ref": "#/$defs/rational"}},
        "steps": {"type": "array", "minItems": 1, "maxItems": 10000, "items": {"type": "object", "properties": {"transformation_id": {"type": "string", "minLength": 1, "maxLength": 256}, "multiplier": {"$ref": "#/$defs/rational"}}, "required": ["transformation_id", "multiplier"], "unevaluatedProperties": false}},
        "source_refs": {"$ref": "#/$defs/idArray"},
        "transformation_refs": {"$ref": "#/$defs/idArray"},
        "feasible_flux": {"type": "object", "minProperties": 1, "maxProperties": 10000, "additionalProperties": {"$ref": "#/$defs/rational"}},
        "rate_intervals": {"type": "object", "minProperties": 1, "maxProperties": 10000, "additionalProperties": {"$ref": "#/$defs/interval"}},
        "covered_siphons": {"type": "array", "maxItems": 100000, "uniqueItems": true, "items": {"$ref": "#/$defs/idArray"}},
        "balance_mode": {"enum": ["steady_state", "self_maintenance"]},
        "internal_coordinates": {"$ref": "#/$defs/idArray"},
        "boundary_coordinates": {"$ref": "#/$defs/idArray"},
        "potential_weights": {"type": "object", "maxProperties": 10000, "additionalProperties": {"$ref": "#/$defs/rational"}},
        "scenarios": {"type": "array", "minItems": 1, "maxItems": 256, "items": {"type": "object", "properties": {"scenario_id": {"type": "string", "minLength": 1, "maxLength": 256}, "remove_subjects": {"$ref": "#/$defs/idArray"}, "remove_key_ids": {"$ref": "#/$defs/idArray"}}, "required": ["scenario_id", "remove_subjects", "remove_key_ids"], "unevaluatedProperties": false}},
        "acceptance_dimensions": {"$ref": "#/$defs/idArray"},
        "executable": {"type": "string", "minLength": 1, "maxLength": 4096},
        "executable_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "argv_prefix": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"type": "string", "minLength": 1, "maxLength": 4096}},
        "arguments": {"type": "array", "maxItems": 256, "items": {"type": "string", "maxLength": 4096}},
        "execution_policy": {"$ref": "execution-policy.schema.json"},
        "output_schema_ref": {"type": "string", "minLength": 1, "maxLength": 1024},
        "outcome_selector": {"type": "object", "properties": {"source_pointer": {"type": "string", "maxLength": 4096}, "mapping": {"type": "object", "maxProperties": 16, "additionalProperties": {"enum": ["success", "partial", "failure", "timeout"]}}}, "required": ["source_pointer", "mapping"], "unevaluatedProperties": false},
        "input_refs": {"$ref": "#/$defs/idArray"},
        "required_authority_refs": {"$ref": "#/$defs/idArray"},
        "required_hazard_refs": {"$ref": "#/$defs/idArray"},
        "expires_at": {"type": "string", "format": "date-time"},
        "repeatable": {"type": "boolean"},
        "branches": {"type": "object", "properties": {"success": {"$ref": "#/$defs/branch"}, "partial": {"$ref": "#/$defs/branch"}, "failure": {"$ref": "#/$defs/branch"}, "timeout": {"$ref": "#/$defs/branch"}}, "required": ["success", "partial", "failure", "timeout"], "unevaluatedProperties": false},
        "must_add": {"$ref": "#/$defs/idArray"},
        "resource_intervals": {"type": "object", "maxProperties": 10000, "additionalProperties": {"$ref": "#/$defs/interval"}},
        "debt": {"$ref": "#/$defs/idArray"},
        "verification_load": {"$ref": "#/$defs/rational"},
        "independence_erosion": {"type": "integer", "minimum": 0}
      },
      "unevaluatedProperties": false
    }
  },
  "type": "object",
  "properties": {
    "schema_version": {"const": "0.4.0"},
    "attestation_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "record_type": {"enum": ["state", "transformation", "resource_observation", "boundary_supply", "catalyst", "inhibitor", "verifier", "authority", "hazard", "independence", "infrastructure", "lineage", "exposure", "evidence"]},
    "subject_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "subject_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "source_artifact_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "source_pointer": {"type": "string", "pattern": "^(?:/(?:[^~/]|~0|~1)*)*$", "maxLength": 4096},
    "lifecycle": {"enum": ["active", "withdrawn", "expired", "revoked"]},
    "valid_from": {"type": "string", "format": "date-time"},
    "valid_until": {"type": "string", "format": "date-time"},
    "lineage_refs": {"$ref": "#/$defs/idArray"},
    "correlation_domains": {"$ref": "#/$defs/idArray"},
    "attributes": {"$ref": "#/$defs/attributes"},
    "extensions": {"type": "object", "propertyNames": {"pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$"}}
  },
  "required": ["schema_version", "attestation_id", "record_type", "subject_id", "subject_digest", "source_artifact_digest", "source_pointer", "lifecycle", "valid_from", "valid_until", "lineage_refs", "correlation_domains", "attributes"],
  "unevaluatedProperties": false
}

        "required": [
          "status",
          "code",
          "effect_class",
          "trace_id"
        ],
        "title": "ApiResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "OperationRequest": {
        "additionalProperties": false,
        "description": "Closed digest-only request used to enqueue authoritative admission work.",
        "properties": {
          "scenario_id": {
            "anyOf": [
              {
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scenario Id"
          },
          "session_id": {
            "anyOf": [
              {
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Session Id"
          },
          "subject_digests": {
            "items": {
              "type": "string"
            },
            "maxItems": 10000,
            "title": "Subject Digests",
            "type": "array"
          }
        },
        "title": "OperationRequest",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "WorkspaceCreate": {
        "additionalProperties": false,
        "properties": {
          "genesis_envelope_fingerprint": {
            "pattern": "^sha256:[0-9a-f]{64}$",
            "title": "Genesis Envelope Fingerprint",
            "type": "string"
          },
          "root_spki_fingerprint": {
            "pattern": "^sha256:[0-9a-f]{64}$",
            "title": "Root Spki Fingerprint",
            "type": "string"
          },
          "workspace_id": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
            "title": "Workspace Id",
            "type": "string"
          }
        },
        "required": [
          "workspace_id",
          "root_spki_fingerprint",
          "genesis_envelope_fingerprint"
        ],
        "title": "WorkspaceCreate",
        "type": "object"
      }
    },

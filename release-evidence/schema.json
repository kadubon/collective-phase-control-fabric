{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cpcf.io/schemas/release-evidence-v1.json",
  "$comment": "SPDX-License-Identifier: Apache-2.0",
  "title": "CPCF stable release evidence manifest",
  "type": "object",
  "required": ["schema_version", "release_version", "commit_sha", "gates"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "cpcf.io/release-evidence/v1"},
    "release_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "gates": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["name", "passed", "independent", "evidence_digest", "details"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "enum": ["availability_soak", "backup_restore", "load_profile", "chaos_profile", "threat_model_review", "penetration_test"]
          },
          "passed": {"const": true},
          "independent": {"type": "boolean"},
          "evidence_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "details": {"type": "object"}
        }
      }
    }
  }
}
